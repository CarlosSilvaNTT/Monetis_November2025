# ========== Monetis URLs ==========
# Update to your real environments
MONETIS_LOGIN_URL=https://monetis-delta.vercel.app/login
MONETIS_DASHBOARD_URL=https://monetis-delta.vercel.app/dashboard

# ========== Credentials ==========
# (Never commit real creds to Git)
MONETIS_USERNAME=testing_carlod@example.com
MONETIS_PASSWORD=testingPassword!1

# ========== Selectors (update to real markup) ==========
MONETIS_USERNAME_SELECTOR=input[name="email"]
MONETIS_PASSWORD_SELECTOR=input[name="password"]
MONETIS_LOGIN_BUTTON_SELECTOR=button[type="submit"]

# ========== Dashboard Ready State ==========
MONETIS_DASHBOARD_READY_SELECTOR=.dashboard

# Optional popup (cookie banners, modals, etc.)
MONETIS_OPTIONAL_POPUP_CLOSE_SELECTOR=.close-popup